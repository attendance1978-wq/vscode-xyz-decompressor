{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "XYZ Archive",
  "scopeName": "source.xyz",
  "patterns": [
    { "include": "#comments" },
    { "include": "#header" },
    { "include": "#metadata" },
    { "include": "#entries" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#strings" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.xyz",
          "match": "#.*$"
        }
      ]
    },
    "header": {
      "patterns": [
        {
          "name": "keyword.control.header.xyz",
          "match": "^XYZ_ARCHIVE\\s+v[0-9]+\\.[0-9]+"
        }
      ]
    },
    "metadata": {
      "patterns": [
        {
          "name": "storage.type.metadata.xyz",
          "match": "^(CREATED|MODIFIED|AUTHOR|CHECKSUM|COMPRESSION|ENCRYPTION|ENTRIES):"
        }
      ]
    },
    "entries": {
      "patterns": [
        {
          "name": "entity.name.function.entry.xyz",
          "match": "^ENTRY\\s+[0-9]+"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.other.xyz",
          "match": "\\b(DEFLATE|STORE|BZIP2|LZMA|AES256|CRC32|SHA256|DIR|FILE|SYMLINK)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.xyz",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.xyz",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.xyz",
              "match": "\\\\."
            }
          ]
        }
      ]
    }
  }
}
